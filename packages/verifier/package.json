{
  "name": "@chainvue/v402-verifier",
  "version": "0.1.2",
  "description": "Framework-agnostic verification core of v402: multi-scheme registry and the verus-prepaid-sig verifier (RPC mode) — amount pre-check, extension validation, bodyHash policy, timestamp window, two-phase debit against injected storage.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chainvue/v402.git",
    "directory": "packages/verifier"
  },
  "homepage": "https://github.com/chainvue/v402/tree/main/packages/verifier#readme",
  "bugs": "https://github.com/chainvue/v402/issues",
  "license": "Apache-2.0",
  "author": "Robert Lech (chainvue)",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json",
    "test": "vitest run"
  },
  "dependencies": {
    "@chainvue/v402-protocol": "workspace:^",
    "@chainvue/v402-signer-verus": "workspace:^",
    "@chainvue/v402-storage": "workspace:^",
    "@chainvue/v402-verus-rpc": "workspace:^"
  },
  "publishConfig": {
    "access": "public"
  }
}
