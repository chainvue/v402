{
  "name": "@chainvue/v402-proxy",
  "version": "0.1.2",
  "description": "v402 reverse proxy: a standalone payment guard in front of ANY origin (static site, WordPress, arbitrary API). Matches route rules, challenges with 402, verifies/reserves via a v402 facilitator (HTTP mode), streams paid requests through to the upstream \u2014 no origin changes required.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chainvue/v402.git",
    "directory": "packages/proxy"
  },
  "homepage": "https://github.com/chainvue/v402/tree/main/packages/proxy#readme",
  "bugs": "https://github.com/chainvue/v402/issues",
  "license": "Apache-2.0",
  "author": "Robert Lech (chainvue)",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "v402-proxy": "./dist/main.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json",
    "test": "vitest run",
    "start": "node --enable-source-maps dist/main.js"
  },
  "dependencies": {
    "@chainvue/v402-protocol": "workspace:^",
    "@chainvue/v402-verifier": "workspace:^",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@chainvue/v402-client-fetch": "workspace:^",
    "@chainvue/v402-facilitator": "workspace:^",
    "@chainvue/v402-signer-verus": "workspace:^",
    "@chainvue/v402-storage": "workspace:^",
    "@chainvue/v402-verus-rpc": "workspace:^",
    "@nestjs/common": "^11.1.28",
    "@nestjs/core": "^11.1.28",
    "@nestjs/testing": "^11.1.28",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "publishConfig": {
    "access": "public"
  }
}
