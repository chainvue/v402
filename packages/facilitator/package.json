{
  "name": "@chainvue/v402-facilitator",
  "version": "0.2.0",
  "description": "Standalone v402 facilitator daemon: verify/reserve/commit/rollback API, balance state, deposit watching, discovery \u2014 NestJS, Pino JSON logs, Prometheus metrics, Zod-validated config.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chainvue/v402.git",
    "directory": "packages/facilitator"
  },
  "homepage": "https://github.com/chainvue/v402/tree/main/packages/facilitator#readme",
  "bugs": "https://github.com/chainvue/v402/issues",
  "license": "Apache-2.0",
  "author": "Robert Lech (chainvue)",
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json",
    "test": "vitest run",
    "start": "node --enable-source-maps dist/main.js",
    "start:dev": "tsx watch --env-file=../../.env src/main.ts"
  },
  "dependencies": {
    "@chainvue/v402-deposit-watcher": "workspace:^",
    "@chainvue/v402-protocol": "workspace:^",
    "@chainvue/v402-storage": "workspace:^",
    "@chainvue/v402-storage-sqlite": "workspace:^",
    "@chainvue/v402-verifier": "workspace:^",
    "@chainvue/v402-verus-rpc": "workspace:^",
    "@nestjs/common": "^11.1.28",
    "@nestjs/core": "^11.1.28",
    "@nestjs/platform-express": "^11.1.28",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/throttler": "^6.5.0",
    "@willsoto/nestjs-prometheus": "^6.1.0",
    "cron": "^4.4.0",
    "nestjs-pino": "^4.6.1",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "prom-client": "^15.1.3",
    "qrcode": "^1.5.4",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@nestjs/testing": "^11.1.28",
    "@types/qrcode": "^1.5.6",
    "@types/supertest": "^7.2.0",
    "ajv": "^8.20.0",
    "pino-pretty": "^13.1.3",
    "supertest": "^7.2.2",
    "tsx": "^4.19.0",
    "yaml": "^2.9.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
