{
  "name": "@chainvue/v402-facilitator",
  "version": "0.1.0",
  "description": "Standalone v402 facilitator daemon: verify/reserve/commit/rollback API, balance state, deposit watching, discovery — NestJS, Pino JSON logs, Prometheus metrics, Zod-validated config.",
  "license": "Apache-2.0",
  "author": "Robert Lech (chainvue)",
  "type": "module",
  "main": "./dist/main.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json",
    "test": "vitest run",
    "start": "node --enable-source-maps dist/main.js",
    "start:dev": "tsx watch --env-file=../../.env src/main.ts"
  },
  "dependencies": {
    "@chainvue/v402-deposit-watcher": "workspace:*",
    "@chainvue/v402-protocol": "workspace:*",
    "@chainvue/v402-storage": "workspace:*",
    "@chainvue/v402-storage-sqlite": "workspace:*",
    "@chainvue/v402-verifier": "workspace:*",
    "@chainvue/v402-verus-rpc": "workspace:*",
    "@nestjs/common": "^11.1.28",
    "@nestjs/core": "^11.1.28",
    "@nestjs/platform-express": "^11.1.28",
    "@willsoto/nestjs-prometheus": "^6.1.0",
    "nestjs-pino": "^4.6.1",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "prom-client": "^15.1.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@nestjs/testing": "^11.1.28",
    "@types/supertest": "^7.2.0",
    "pino-pretty": "^13.1.3",
    "supertest": "^7.2.2",
    "tsx": "^4.19.0"
  }
}
