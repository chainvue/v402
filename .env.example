# v402 environment template.
# Copy to `.env` and fill in values. `.env` is gitignored — real secrets never enter the repo.
# Everything not listed here has a config default (see the environment
# reference in docs/integration/facilitator-docker.md);
# only secret or environment-specific values live in env vars.

# ── Runtime ─────────────────────────────────────────────────────────────────
# development | production | test
NODE_ENV=

# ── Verus RPC (facilitator + verifier, RPC-mode signature verification) ─────
# e.g. http://127.0.0.1:18843 (your vrsctest node)
VERUS_RPC_URL=
VERUS_RPC_USER=
VERUS_RPC_PASS=

# ── Storage ─────────────────────────────────────────────────────────────────
# SQLite database file path, e.g. ./data/v402.sqlite (WAL mode enabled by config)
DB_PATH=

# ── Facilitator HTTP mode (only when facilitator.mode = 'http') ─────────────
# URL of the standalone facilitator the middleware talks to, e.g. http://localhost:3000
FACILITATOR_URL=
# Per-middleware auth token provisioned by the facilitator operator (HTTP-Basic)
FACILITATOR_AUTH_TOKEN=

# ── Facilitator operator config (non-secret; defaults exist in code) ────────
# HTTP bind, e.g. 3000 / 127.0.0.1
PORT=
HOST=
# Domain the payment signatures are bound to, e.g. explorer.example.com
V402_CANONICAL_DOMAIN=
# Receiving identity (payTo + deposit address), e.g. explorerAPI@
V402_PAY_TO=
# real | simulated (simulated refuses NODE_ENV=production without override)
V402_WATCHER_MODE=
# rpc (default: verifymessage per request) | offline (local pubkey recovery,
# identity state cached — revocation takes effect within the cache TTL)
V402_VERIFIER_MODE=
# offline mode: identity-state cache TTL in seconds (default 60)
V402_IDENTITY_CACHE_TTL_SEC=
# pino level: fatal|error|warn|info|debug|trace|silent
LOG_LEVEL=

# ── Ops / admin ─────────────────────────────────────────────────────────────
# Token guarding /admin/* endpoints (simulate-deposit, credit, reconcile)
V402_ADMIN_TOKEN=
# Safety override: simulated deposit-watcher refuses to boot with
# NODE_ENV=production unless this is explicitly "true". Leave empty.
V402_ALLOW_SIMULATED_IN_PROD=

# ── Client-side (EnvSigner in @chainvue/v402-signer-verus) ──────────────────
# WIF-encoded signing key for headless deployments without a local Verus node.
# Use a secret manager in production; never log this value.
VERUS_SIGNING_KEY=
